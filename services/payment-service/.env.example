PORT=5006
NODE_ENV=development

# Set to true to force mock checkout links even if Stripe key exists
PAYMENT_MOCK_ONLY=true

# For Stripe test mode, create a key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=

# Frontend/payment redirect URLs
FRONTEND_BASE_URL=http://localhost:3000
PAYMENT_SUCCESS_URL=http://localhost:3000/payments/success?session_id={CHECKOUT_SESSION_ID}
PAYMENT_CANCEL_URL=http://localhost:3000/payments/cancel
